<%- include('partials/header') %>
<div class="bg-grid"></div>
<div class="bg-orbs"></div>
<main class="section container" style="margin-top: 40px; padding-top: 0;">
    <div class="text-center mb-5 reveal" style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
        <div class="hero-eyebrow" style="margin-bottom: 1.5rem;">
            <span class="hero-eyebrow-dot"></span>
            MEMBER HUB
        </div>

        <h1 class="hero-title" style="display: flex; align-items: center; gap: 20px; white-space: nowrap; font-size: clamp(2.2rem, 7vw, 4rem); margin-bottom: 1rem;">
            <span>Welcome,</span>
            <span class="hero-title-line2" style="margin: 0; display: inline-block;">
                <%= typeof user !== 'undefined' && user ? (user.name || user.email) : 'Guest' %>
            </span>
        </h1>

        <p class="hero-subtitle mx-auto" style="max-width: 600px; opacity: 0.8;">
            View your active tickets and manage your upcoming experiences.
        </p>
    </div>

    <% if (typeof success !== 'undefined') { %>
        <div class="alert alert-success" style="margin-bottom: 1.5rem;">
            <i class="fa-solid fa-circle-check"></i>
            Booking confirmed successfully!
        </div>
    <% } %>

    <div class="row g-4 mb-5 reveal">
        <div class="col-md-6">
            <div class="table-container" style="padding: 2.5rem; text-align: center;">
                <p style="color: var(--neon-purple); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">Total Bookings</p>
                <h2 style="color: white; font-weight: 800; font-size: 3rem; margin: 0;"><%= totalTickets %></h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="table-container" style="padding: 2.5rem; text-align: center;">
                <p style="color: var(--neon-purple); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">Member Status</p>
                <h2 style="color: white; font-weight: 800; font-size: 3rem; margin: 0;">
                    <%= totalTickets >= 5 ? 'VIP' : 'Standard' %>
                </h2>
            </div>
        </div>
    </div>

    <div class="table-container reveal">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--dark-border); display: flex; justify-content: space-between; align-items: center;">
            <h4 style="color: white; margin: 0; font-weight: 700;">My Bookings</h4>
            <a href="/events" class="btn btn-sm btn-ghost">BOOK NEW EVENT</a>
        </div>
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Tickets</th>
                    <th>Price/Ticket</th>
                    <th>Total Cost</th>
                    <th style="text-align: right;">Status</th>
                </tr>
            </thead>
        <tbody>
            <% if (bookings && bookings.length > 0) { %>
                <% bookings.forEach(booking => { %>
                    <tr>
                        <td style="font-weight: 600; color: white;">
                            <%= booking.EventID ? booking.EventID.Name : 'Event Removed' %>
                        </td>
                        <td>
                            <span class="float-badge-available">
                                <%= booking.EventID ? booking.EventID.Category : '-' %>
                            </span>
                        </td>
                        <td>
                            <%= booking.EventID ? new Date(booking.EventID.Date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) : '-' %>
                        </td>
                        <td><%= booking.Tickets %></td>
                        <td>R <%= booking.EventID ? (booking.EventID.TicketPrice || 0).toFixed(2) : '0.00' %></td>
                        <td>R <%= booking.EventID ? ((booking.EventID.TicketPrice || 0) * booking.Tickets).toFixed(2) : '0.00' %></td>
                        <td style="text-align: right;">
                            <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.75rem;">
                                <span style="color: #00ff88; font-weight: 700; font-size: 0.8rem;">● CONFIRMED</span>

                                <!-- Edit tickets form -->
                                <form action="/bookings/<%= booking._id %>/edit" method="POST" 
                                      style="display: flex; align-items: center; gap: 0.4rem;">
                                    <input type="number" name="tickets" value="<%= booking.Tickets %>" 
                                           min="1" 
                                           max="<%= booking.EventID ? booking.EventID.Capacity - (booking.EventID.Bookings || 0) + booking.Tickets : 1 %>"
                                           class="form-control" style="width: 65px; padding: 0.3rem 0.5rem;" />
                                    <button type="submit" class="btn btn-sm btn-ghost">Update</button>
                                </form>

                                <!-- Cancel form -->
                                <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-ghost btn-delete">Cancel</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                        No bookings yet. <a href="/events" style="color: var(--neon-purple);">Browse events</a>
                    </td>
                </tr>
            <% } %>
        </tbody>
        </table>
    </div>
</main>

<%- include('partials/footer') %>