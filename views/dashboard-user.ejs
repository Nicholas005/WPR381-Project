<%- include('header') %>

<main class="section container" style="margin-top: 40px; padding-top: 0;">
    <div class="text-center mb-5 reveal" style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
        <div class="hero-eyebrow" style="margin-bottom: 1.5rem;">
            <span class="hero-eyebrow-dot"></span>
            MEMBER HUB
        </div>

        <h1 class="hero-title" style="display: flex; align-items: center; gap: 20px; white-space: nowrap; font-size: clamp(2.2rem, 7vw, 4rem); margin-bottom: 1rem;">
            <span>Welcome,</span>
            <span class="hero-title-line2" style="margin: 0; display: inline-block;">Jade</span>
        </h1>

        <p class="hero-subtitle mx-auto" style="max-width: 600px; opacity: 0.8;">
            View your active tickets and manage your upcoming midnight experiences.
        </p>
    </div>

    <div class="row g-4 mb-5 reveal">
        <div class="col-md-6">
            <div class="table-container" style="padding: 2.5rem; background: var(--cardBg); border: 1px solid var(--border); text-align: center;">
                <p style="color: var(--accent); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">Total Tickets</p>
                <h2 style="color: white; font-weight: 800; font-size: 3rem; margin: 0;">08</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="table-container" style="padding: 2.5rem; background: var(--cardBg); border: 1px solid var(--border); text-align: center;">
                <p style="color: var(--accent); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">Loyalty Points</p>
                <h2 style="color: white; font-weight: 800; font-size: 3rem; margin: 0;">1,250</h2>
            </div>
        </div>
    </div>

    <div class="table-container reveal" style="background: var(--cardBg); border: 1px solid var(--border); overflow: hidden;">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
            <h4 style="color: white; margin: 0; font-weight: 700;">Active Bookings</h4>
            <a href="/events" class="btn btn-sm btn-ghost">BOOK NEW EVENT</a>
        </div>
        <div class="table-responsive">
            <table class="table" style="color: var(--textSecondary); margin-bottom: 0;">
                <thead style="background: rgba(255,255,255,0.02);">
                    <tr>
                        <th style="padding: 1.2rem; color: var(--accent); font-size: 0.7rem; border: none;">EVENT</th>
                        <th style="padding: 1.2rem; color: var(--accent); font-size: 0.7rem; border: none;">DATE</th>
                        <th style="padding: 1.2rem; color: var(--accent); font-size: 0.7rem; border: none; text-align: right;">STATUS</th>
                    </tr>
                </thead>
                <tbody style="border: none;">
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <td style="padding: 1.2rem; color: white; font-weight: 600;">Neon Nights Festival</td>
                        <td style="padding: 1.2rem;">24 May 2026</td>
                        <td style="padding: 1.2rem; text-align: right;">
                            <span style="color: #00ff88; font-weight: 700; font-size: 0.8rem;">● CONFIRMED</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('footer') %>