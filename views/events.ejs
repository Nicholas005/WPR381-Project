<%- include('partials/header') %>

<main class="container" style="position: relative; z-index: 1; padding-bottom: 4rem;">

    <!-- Page Header -->
    <div class="hero-section-center" style="margin-top: 60px; margin-bottom: 2.5rem;">
        <div class="hero-eyebrow eyebrow-center">
            <span class="hero-eyebrow-dot"></span>
            Live & Upcoming
        </div>
        <h1 class="hero-title-line2" style="font-size: clamp(2rem, 5vw, 3.5rem);">All Events</h1>
        <p style="color: var(--text-secondary); margin-top: 0.75rem;">Browse and book your next experience</p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="filter-group">
            <label class="filter-label">Search</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Search events..." oninput="filterEvents()" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Category</label>
            <select id="categoryFilter" class="form-control" onchange="filterEvents()">
                <option value="">All Categories</option>
                <option value="CORPORATE">Corporate</option>
                <option value="WORKSHOP">Workshop</option>
                <option value="FESTIVAL">Festival</option>
                <option value="PRIVATE">Private</option>
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Availability</label>
            <select id="availFilter" class="form-control" onchange="filterEvents()">
                <option value="">All</option>
                <option value="available">Available</option>
                <option value="sold-out">Sold Out</option>
            </select>
        </div>
    </div>

    <!-- Events Grid -->
    <% if (events.length === 0) { %>
        <div style="text-align: center; padding: 4rem; color: var(--text-secondary);">
            <i class="fa-solid fa-calendar-xmark" style="font-size: 3rem; color: var(--neon-purple); margin-bottom: 1rem; display: block;"></i>
            <p>No events available at the moment.</p>
        </div>
    <% } else { %>
        <div class="events-grid" id="eventsGrid">
            <% events.forEach(event => { %>
                <% const available = event.Capacity - event.Bookings; %>
                <% const isSoldOut = available <= 0; %>
                <% const isLimited = available > 0 && available <= 20; %>
                <div class="event-card" 
                     data-category="<%= event.Category %>" 
                     data-name="<%= event.Name %>"
                     data-available="<%= isSoldOut ? 'sold-out' : 'available' %>">
                    
                    <div class="event-card-image">
                        <div class="event-card-image-placeholder">
                            <% if (event.Category === 'CORPORATE') { %>🏢
                            <% } else if (event.Category === 'WORKSHOP') { %>🛠️
                            <% } else if (event.Category === 'FESTIVAL') { %>🎉
                            <% } else { %>🎟️<% } %>
                        </div>
                        <span class="event-category-badge <%= event.Category === 'CORPORATE' ? 'badge-conference' : event.Category === 'FESTIVAL' ? 'badge-festival' : event.Category === 'WORKSHOP' ? 'badge-workshop' : 'badge-private' %>">
                            <%= event.Category %>
                        </span>
                        <span class="availability-badge <%= isSoldOut ? 'badge-sold-out' : isLimited ? 'badge-limited' : 'badge-available' %>">
                            <%= isSoldOut ? 'Sold Out' : isLimited ? 'Limited' : 'Available' %>
                        </span>
                    </div>

                    <div class="event-card-body">
                        <div class="event-card-title"><%= event.Name %></div>
                        <div class="event-card-meta">
                            <div class="event-meta-item">
                                <i class="fa-solid fa-calendar icon"></i>
                                <%= new Date(event.Date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </div>
                            <div class="event-meta-item">
                                <i class="fa-solid fa-users icon"></i>
                                <%= available %> / <%= event.Capacity %> spots left
                            </div>
                            <div class="event-meta-item">
                                <i class="fa-solid fa-tag icon"></i>
                            R <%= (event.TicketPrice || 0).toFixed(2) %> per ticket
                            </div>
                        </div>
                        <div class="event-card-price">
                            <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.4rem;">
                                <span style="background: var(--neon-purple); color: #fff; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px;">
                                    <i class="fa-solid fa-users"></i> <%= available %> spots left
                                </span>
                                <span style="background: var(--neon-blue, #00cfff); color: #000; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px;">
                                    R <%= (event.TicketPrice || 0).toFixed(2) %> / ticket
                                </span>
                            </div>
                            <% if (typeof user !== 'undefined' && user && user.role !== 'admin') { %>
                                <% if (!isSoldOut) { %>
                                    <form action="/bookings/<%= event._id %>" method="POST" style="display:inline; display:flex; gap:0.5rem; align-items:center;">
                                        <input type="number" name="tickets" value="1" min="1" max="<%= available %>" 
                                            class="form-control" style="width: 70px; padding: 0.4rem;" />
                                        <button type="submit" class="btn btn-primary btn-sm">Book Now</button>
                                    </form>
                                <% } else { %>
                                    <button class="btn btn-ghost btn-sm" disabled>Sold Out</button>
                                <% } %>
                            <% } else if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                                <span style="font-size: 0.75rem; color: var(--text-muted);">Admin View</span>
                            <% } else { %>
                                <a href="/auth/login" class="btn btn-outline btn-sm">Login to Book</a>
                            <% } %>
                        </div>
                    </div>

                </div>
            <% }) %>
        </div>
    <% } %>

</main>

<script>
function filterEvents() {
    const search   = document.getElementById('searchInput').value.toLowerCase();
    const category = document.getElementById('categoryFilter').value;
    const avail    = document.getElementById('availFilter').value;

    document.querySelectorAll('.event-card').forEach(card => {
        const name     = card.dataset.name.toLowerCase();
        const cat      = card.dataset.category;
        const cardAvail = card.dataset.available;

        const matchSearch   = name.includes(search);
        const matchCategory = !category || cat === category;
        const matchAvail    = !avail || cardAvail === avail;

        card.style.display = (matchSearch && matchCategory && matchAvail) ? '' : 'none';
    });
}
</script>

<%- include('partials/footer') %>