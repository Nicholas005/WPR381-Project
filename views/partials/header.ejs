<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Advanced Events' %> | Smart Ticketing</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav class="navbar" role="navigation">
    <div class="container">
        <div class="navbar-inner">

            <a href="/" class="navbar-brand">
                <div class="brand-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div class="brand-text">
                    <span class="brand-name">Advanced Events</span>
                    <span class="brand-sub">Smart Ticketing System</span>
                </div>
            </a>

            <ul class="navbar-nav" id="navbarMenu">
                <li class="nav-item">
                    <a href="/" class="nav-link <%= (typeof title !== 'undefined' && title === 'Home') ? 'active' : '' %>">Home</a>
                </li>

                <li class="nav-item">
                    <a href="/events" class="nav-link <%= (typeof title !== 'undefined' && title === 'Events') ? 'active' : '' %>">Events</a>
                </li>

                <% if (typeof user !== 'undefined' && user) { %>
                    <li class="nav-item">
                        <a href="/dashboard" class="nav-link">Dashboard</a>
                    </li>

                    <% if (user.role === 'admin') { %>
                        <li class="nav-item">
                            <a href="/admin/events" class="nav-link">
                                <i class="bi bi-gear-fill"></i> Manage
                            </a>
                        </li>
                    <% } %>
                <% } %>

                <li class="nav-item">
                    <a href="/contact" class="nav-link">Contact</a>
                </li>
            </ul>

            <div class="navbar-actions">
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="user-pill">
                        <div class="user-avatar">
                            <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <div class="user-info">
                            <span class="user-name"><%= user.name || 'User' %></span>
                        </div>
                    </div>
                    <a href="/auth/logout" class="btn btn-ghost btn-sm">Logout</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-ghost">Login</a>
                    <a href="/auth/register" class="btn btn-primary">Join Now</a>
                <% } %>
            </div>

            <button class="navbar-toggle" id="navbarToggle">☰</button>

        </div>
    </div>
</nav>

<% if (typeof messages !== 'undefined') { %>
    <div class="container mt-3">
        <% if (messages.success) { %>
            <% messages.success.forEach(msg => { %>
                <div class="alert alert-success">
                    <span><i class="bi bi-check-circle-fill"></i> <%= msg %></span>
                    <button class="alert-close">✕</button>
                </div>
            <% }) %>
        <% } %>
        
        <% if (messages.error) { %>
            <% messages.error.forEach(msg => { %>
                <div class="alert alert-error">
                    <span><i class="bi bi-exclamation-triangle-fill"></i> <%= msg %></span>
                    <button class="alert-close">✕</button>
                </div>
            <% }) %>
        <% } %>
    </div>
<% } %>