<%- include('partials/header') %>

<div class="bg-grid"></div>
<div class="bg-orbs"></div>

<div class="wrapper">
  <main class="main-content" style="padding-top: 3rem;">
    <div class="container">

      <!-- Page heading -->
      <div class="text-center reveal" style="margin-top:40px; padding-top:0;">

        <div class="hero-eyebrow" style="margin-bottom: 1.5rem;">
          <span class="hero-eyebrow-dot"></span>
          Reach Out
        </div>

        <h1 class="hero-title" style=" white-space: nowrap; font-size: clamp(2.2rem, 7vw, 4rem); margin-top: 80px; padding-top:0;">
            <span>Get in</span>
            <span class="hero-title-line2" style="margin: 0; display: inline-block;">Touch</span>
        </h1>

        <p style="color: var(--text-secondary); max-width: 480px; margin: 0 auto; font-size: 1rem;">
          Have a question about an event or need support? We respond within 24 hours.
        </p>

      </div>

      
      <div style="
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 2rem;
        align-items: start;
        margin-bottom: 4rem;
      " class="contact-grid">

        <!-- LEFT - Contact form -->
        <div class="card reveal" style="padding: 0; overflow: hidden;">

          <!-- Card header bar -->
          <div style="
            padding: 1.4rem 1.75rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            gap: 10px;
          ">
            <i class="fa-solid fa-paper-plane" style="color: var(--neon-amber);"></i>
            <h4 style="margin: 0; font-size: 1rem; font-weight: 700; color: var(--text-primary);">
              Send a Message
            </h4>
          </div>

          <!-- The actual form -->
          <div style="padding: 2rem 1.75rem;">

            <!-- Flash messages from the controller -->
            <% if (typeof success !== 'undefined' && success) { %>
              <div class="alert alert-success">
                <i class="fa-solid fa-circle-check"></i>
                <%= success %>
              </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-error">
                <i class="fa-solid fa-circle-xmark"></i>
                <%= error %>
              </div>
            <% } %>

            <form action="/contact/send" method="POST">

              <!-- Name and email side by side -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">

                <div class="form-group" style="margin-bottom: 0;">
                  <label class="form-label">Full Name</label>
                  <!-- If user is logged in, pre-fill their name -->
                  <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Jane Doe"
                    value="<%= typeof user !== 'undefined' && user ? (user.firstName + ' ' + (user.lastName || '')).trim() : '' %>"
                    required
                  />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                  <label class="form-label">Email Address</label>
                  <!-- Pre-fill email if logged in -->
                  <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="jane@example.com"
                    value="<%= typeof user !== 'undefined' && user ? user.email : '' %>"
                    required
                  />
                </div>

              </div>

              <!-- Subject dropdown -->
              <div class="form-group">
                <label class="form-label">Subject</label>
                <select name="subject" class="form-control">
                  <option value="General Enquiry">General Enquiry</option>
                  <option value="Booking Support">Booking Support</option>
                  <option value="Event Hosting">Event Hosting</option>
                  <option value="Technical Issue">Technical Issue</option>
                  <option value="Refund Request">Refund Request</option>
                </select>
              </div>

              <!-- Message textarea -->
              <div class="form-group">
                <label class="form-label">Message</label>
                <textarea
                  name="message"
                  class="form-control"
                  rows="5"
                  placeholder="How can we help you today?"
                  required
                ></textarea>
              </div>

              <!-- Submit button -->
              <button type="submit" class="btn btn-primary w-full" style="
                width: 100%;
                justify-content: center;
                padding: 0.9rem;
                font-size: 0.85rem;
                margin-top: 0.5rem;
              ">
                <i class="fa-solid fa-paper-plane"></i>
                Send Message
              </button>

            </form>
          </div>
        </div>
        <!-- end form card -->

        <!-- RIGHT - Contact info -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;" class="reveal">

          <!-- Each info card -->
          <div class="card" style="padding: 1.5rem;">
            <div style="display: flex; align-items: flex-start; gap: 1rem;">
              <!-- Icon box -->
              <div style="
                width: 40px; height: 40px;
                background: rgba(245, 158, 11, 0.12);
                border: 1px solid rgba(245, 158, 11, 0.25);
                border-radius: 10px;
                display: flex; align-items: center; justify-content: center;
                color: var(--neon-amber);
                flex-shrink: 0;
              ">
                <i class="fa-solid fa-location-dot"></i>
              </div>
              <div>
                <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--neon-amber); margin-bottom: 5px; font-weight: 600;">
                  Main Office
                </div>
                <div style="color: var(--text-primary); font-size: 0.92rem; font-weight: 600; margin-bottom: 3px;">
                  123 Innovation Drive
                </div>
                <div style="color: var(--text-muted); font-size: 0.85rem;">
                  Sandton, Johannesburg
                </div>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <div style="display: flex; align-items: flex-start; gap: 1rem;">
              <div style="
                width: 40px; height: 40px;
                background: rgba(249, 115, 22, 0.12);
                border: 1px solid rgba(249, 115, 22, 0.25);
                border-radius: 10px;
                display: flex; align-items: center; justify-content: center;
                color: var(--neon-orange);
                flex-shrink: 0;
              ">
                <i class="fa-solid fa-phone"></i>
              </div>
              <div>
                <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--neon-orange); margin-bottom: 5px; font-weight: 600;">
                  Direct Line
                </div>
                <div style="color: var(--text-primary); font-size: 0.92rem; font-weight: 600; margin-bottom: 3px;">
                  +27 11 000 0000
                </div>
                <div style="color: var(--text-muted); font-size: 0.85rem;">
                  Mon – Fri, 8am – 6pm
                </div>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <div style="display: flex; align-items: flex-start; gap: 1rem;">
              <div style="
                width: 40px; height: 40px;
                background: rgba(245, 158, 11, 0.12);
                border: 1px solid rgba(245, 158, 11, 0.25);
                border-radius: 10px;
                display: flex; align-items: center; justify-content: center;
                color: var(--neon-amber);
                flex-shrink: 0;
              ">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <div>
                <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--neon-amber); margin-bottom: 5px; font-weight: 600;">
                  Email Us
                </div>
                <div style="color: var(--text-primary); font-size: 0.92rem; font-weight: 600; margin-bottom: 3px;">
                  info@smartevents.co.za
                </div>
                <div style="color: var(--text-muted); font-size: 0.85rem;">
                  We reply within 24 hours
                </div>
              </div>
            </div>
          </div>

          <!-- Systems online status pill -->
          <div class="card" style="padding: 1.25rem 1.5rem;">
            <div style="display: flex; align-items: center; gap: 10px;">
              <!-- Pulsing green dot -->
              <div style="
                width: 10px; height: 10px;
                background: #00ff88;
                border-radius: 50%;
                box-shadow: 0 0 8px #00ff88;
                animation: blink 1.8s ease-in-out infinite;
                flex-shrink: 0;
              "></div>
              <div>
                <div style="font-size: 0.78rem; font-weight: 700; color: #00ff88; letter-spacing: 0.08em; text-transform: uppercase;">
                  All Systems Online
                </div>
                <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 2px;">
                  Platform running normally
                </div>
              </div>
            </div>
          </div>

        </div>
        <!-- end right column -->

      </div>
      <!-- end two-column grid -->

    </div>
    <!-- end container -->
  </main>
</div>

<!-- 
  Make the two-column grid stack on smaller screens.
  We add this small style block here so it stays with the page.
-->
<style>
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
    }

    /* Stack name and email inputs on mobile too */
    .contact-grid form > div:first-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<%- include('partials/footer') %>
