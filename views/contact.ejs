<%- include('partials/header') %>
<div class="bg-grid"></div>
<div class="bg-orbs"></div>

<main class="container">
    <div class="hero-section-center">
        <div class="hero-eyebrow eyebrow-center">
            <span class="hero-eyebrow-dot"></span>
            Reach Out
        </div>

        <h1 class="hero-main-title">
            Get in <span class="hero-accent">Touch</span>
        </h1>
    </div>

    <div class="contact-layout-wrapper fade-in">
        <div class="contact-grid">
            
            <div class="auth-card-wrapper" style="margin: 0; max-width: 100%;">
                <div class="card-header-minimal">
                    <i class="fa-solid fa-paper-plane accent-icon"></i>
                    <h4>Send a Message</h4>
                </div>

                <form action="/contact" method="POST">
                    <div class="form-row-dual">
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="name" class="form-control" placeholder="Jane Doe" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="email" class="form-control" placeholder="jane@example.com" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Subject</label>
                        <select name="subject" class="form-control">
                            <option value="General Enquiry">General Enquiry</option>
                                <option value="Booking Support">Booking Support</option>
                                <option value="Technical Issue">Technical Issue</option>
                                <option value="Event Feedback">Event Feedback</option>
                                <option value="Refund Request">Refund Request</option>
                                <option value="Partnership Enquiry">Partnership Enquiry</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Message</label>
                        <textarea name="message" class="form-control" rows="4" placeholder="How can we help?" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 mt-2">
                        SEND MESSAGE
                    </button>
                </form>
            </div>

            <div class="info-column">
                <div class="info-card">
                    <div class="info-icon-box amber"><i class="fa-solid fa-location-dot"></i></div>
                    <div>
                        <span class="info-label">Main Office</span>
                        <p class="info-value">123 Innovation Drive</p>
                        <p class="info-sub">Sandton, Johannesburg</p>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon-box orange"><i class="fa-solid fa-phone"></i></div>
                    <div>
                        <span class="info-label">Direct Line</span>
                        <p class="info-value">+27 11 000 0000</p>
                    </div>
                </div>

                <div class="status-card">
                    <div class="pulse-dot"></div>
                    <div>
                        <span class="status-text">All Systems Online</span>
                        <p class="info-sub">Platform running normally</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

<%- include('partials/footer') %>