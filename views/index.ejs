<%- include('partials/header', { title: 'Browse Events' }) %>

<!-- hero section -->

<section class="hero">
  <div class="container">
    <div class="row align-items-center g-5">

      <!-- left hero content -->

      <div class="col-lg-6 hero-content">

        <div class="hero-badge">
          <span class="dot"></span>
          Live Events Platform
        </div>

        <h1 class="hero-title">
          DISCOVER<br>
          <span class="line-accent">EXTRAORDINARY</span>
          EVENTS
        </h1>

        <p class="hero-subtitle">
          From corporate conferences to electric music festivals book your next unforgettable experience with SmartEvents.
        </p>

        <div class="hero-actions">

          <a href="#events" class="btn btn-primary">
            <i class="bi bi-search"></i>
            Browse Events
          </a>

          <% if (typeof user === 'undefined' || !user) { %>

            <a href="/auth/register" class="btn btn-outline">
              <i class="bi bi-person-plus"></i>
              Join Free
            </a>

          <% } %>

        </div>

        <!-- hero stats -->

        <div class="hero-stats">

          <div>
            <div class="hero-stat-num" data-count="1200">0</div>
            <div class="hero-stat-label">Events Hosted</div>
          </div>

          <div>
            <div class="hero-stat-num" data-count="48000">0</div>
            <div class="hero-stat-label">Happy Attendees</div>
          </div>

          <div>
            <div class="hero-stat-num" data-count="98">0</div>
            <div class="hero-stat-label">% Satisfaction</div>
          </div>

        </div>

      </div>

      <!-- hero right side -->

      <div class="col-lg-6 hero-visual d-none d-lg-block">

        <div class="row g-3">

          <!-- featured card -->

          <div class="col-12">

            <div class="hero-card-float">

              <div class="d-flex align-items-center gap-3 mb-3">

                <div class="hero-icon-box">
                  <i class="bi bi-music-note-beamed"></i>
                </div>

                <div>
                  <div class="hero-card-title">
                    UPCOMING: AfroFusion Fest
                  </div>

                  <div class="hero-card-text">
                    Sat 14 Jun 2025 · Sandton Convention
                  </div>
                </div>

              </div>

              <div class="capacity-bar">
                <div class="capacity-bar-fill" data-fill="72"></div>
              </div>

              <div class="hero-progress-text">
                <span>720 / 1000 tickets sold</span>
                <span>72% full</span>
              </div>

            </div>

          </div>

          <!-- small cards -->

          <div class="col-6">

            <div class="hero-card-float text-center">

              <i class="bi bi-ticket-perforated hero-small-icon"></i>

              <div class="hero-small-number">
                <span data-count="12">0</span>
              </div>

              <div class="hero-small-label">
                Events Today
              </div>

            </div>

          </div>

          <div class="col-6">

            <div class="hero-card-float text-center">

              <i class="bi bi-geo-alt hero-small-icon blue"></i>

              <div class="hero-small-number">
                <span data-count="24">0</span>
              </div>

              <div class="hero-small-label">
                Venues
              </div>

            </div>

          </div>

        </div>

      </div>

    </div>
  </div>
</section>

<!-- category filters -->

<section class="category-section">

  <div class="container">

    <div class="d-flex gap-2 flex-wrap align-items-center">

      <span class="category-label">
        Browse by:
      </span>

      <% const cats = ['All', 'Conference', 'Festival', 'Workshop', 'Music', 'Private']; %>

      <% cats.forEach(cat => {

        const isActive =
          (cat === 'All' && !activeCategory) ||
          (typeof activeCategory !== 'undefined' &&
          activeCategory === cat.toLowerCase());

      %>

      <a
        href="/?category=<%= cat.toLowerCase() === 'all' ? '' : cat.toLowerCase() %>"
        class="category-pill <%= isActive ? 'active' : '' %>"
      >
        <%= cat %>
      </a>

      <% }) %>

    </div>

  </div>

</section>

<!-- events listing -->

<section class="section section-light" id="events">

  <div class="container">

    <div class="row align-items-end mb-4 reveal">

      <div class="col-md-6">

        <div class="section-label">
          Upcoming Events
        </div>

        <h2 class="section-title">
          Find Your <span>Next Experience</span>
        </h2>

      </div>

      <div class="col-md-6 text-md-end mt-3 mt-md-0">

        <span class="events-count">
          Showing
          <strong>
            <%= typeof events !== 'undefined' ? events.length : 0 %>
          </strong>
          events
        </span>

      </div>

    </div>

    <!-- search section -->

    <div class="search-bar-wrapper reveal">

      <div class="row g-3 align-items-end">

        <div class="col-lg-5">

          <label class="form-label-custom">
            <i class="bi bi-search me-1"></i>
            Search Events
          </label>

          <input
            type="text"
            id="eventSearch"
            class="search-input"
            placeholder="Search by event name..."
          />

        </div>

        <div class="col-lg-3">

          <label class="form-label-custom">
            <i class="bi bi-tag me-1"></i>
            Category
          </label>

          <select id="categoryFilter" class="filter-select">

            <option value="">All Categories</option>
            <option value="conference">Conference</option>
            <option value="festival">Festival</option>
            <option value="workshop">Workshop</option>
            <option value="music">Music</option>
            <option value="private">Private</option>

          </select>

        </div>

        <div class="col-lg-3">

          <label class="form-label-custom">
            <i class="bi bi-calendar3 me-1"></i>
            Date
          </label>

          <input
            type="date"
            id="dateFilter"
            class="filter-select"
          />

        </div>

        <div class="col-lg-1">

          <button
            onclick="
              document.getElementById('eventSearch').value='';
              document.getElementById('categoryFilter').value='';
              document.getElementById('dateFilter').value='';
              filterEvents();
            "
            class="btn btn-purple w-100"
          >
            <i class="bi bi-x-lg"></i>
          </button>

        </div>

      </div>

    </div>

    <!-- no results message -->

    <div id="noResults" style="display:none;text-align:center;padding:4rem 0;">

      <div style="font-size:3rem;margin-bottom:1rem;">
        🎭
      </div>

      <h4 class="event-card-title">
        NO EVENTS FOUND
      </h4>

      <p class="hero-subtitle">
        Try adjusting your search filters.
      </p>

    </div>

    <!-- event cards -->

    <div class="row g-4 stagger-children" id="eventsGrid">

      <% if (typeof events !== 'undefined' && events.length > 0) { %>

        <% events.forEach(event => {

          const fillPct = event.capacity > 0
            ? Math.round(((event.booked || 0) / event.capacity) * 100)
            : 0;

          const spotsLeft =
            event.capacity - (event.booked || 0);

        %>

        <div
          class="col-md-6 col-xl-4 event-card-wrapper"
          data-title="<%= event.title.toLowerCase() %>"
          data-category="<%= event.category.toLowerCase() %>"
          data-date="<%= new Date(event.date).toISOString().split('T')[0] %>"
        >

          <div class="event-card">

            <div class="event-card-img">

              <img
                src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&q=80"
                alt="<%= event.title %>"
                loading="lazy"
              />

              <span class="event-card-category">
                <%= event.category %>
              </span>

              <span class="event-card-capacity">
                <i class="bi bi-people-fill me-1"></i>
                <%= spotsLeft %> left
              </span>

            </div>

            <div class="event-card-body">

              <h3 class="event-card-title">
                <%= event.title %>
              </h3>

              <div class="event-meta">

                <div class="event-meta-item">
                  <i class="bi bi-calendar3"></i>

                  <%= new Date(event.date).toLocaleDateString('en-ZA', {
                    weekday:'short',
                    day:'numeric',
                    month:'short',
                    year:'numeric'
                  }) %>

                </div>

                <div class="event-meta-item">
                  <i class="bi bi-geo-alt"></i>
                  <%= event.venue %>
                </div>

                <% if (event.description) { %>

                  <div class="event-meta-item">

                    <%= event.description.substring(0, 90) %>
                    <%= event.description.length > 90 ? '...' : '' %>

                  </div>

                <% } %>

              </div>

              <div class="mt-3 mb-3">

                <div class="d-flex justify-content-between small mb-2">

                  <span>Capacity</span>
                  <span><%= fillPct %>% filled</span>

                </div>

                <div class="capacity-bar">
                  <div
                    class="capacity-bar-fill"
                    data-fill="<%= fillPct %>"
                    style="width:0%;"
                  ></div>
                </div>

              </div>

              <div class="event-card-footer">

                <span class="hero-card-text">
                  <i class="bi bi-ticket-perforated me-1"></i>
                  <%= spotsLeft %> available
                </span>

                <% if (typeof user !== 'undefined' && user) { %>

                  <form
                    action="/bookings/<%= event._id %>"
                    method="POST"
                  >

                    <button
                      type="submit"
                      class="btn btn-purple"
                      <%= spotsLeft === 0 ? 'disabled' : '' %>
                    >

                      <i class="bi bi-ticket me-1"></i>

                      <%= spotsLeft === 0
                        ? 'SOLD OUT'
                        : 'Book Now'
                      %>

                    </button>

                  </form>

                <% } else { %>

                  <a
                    href="/auth/login"
                    class="btn btn-purple"
                  >

                    <i class="bi bi-lock me-1"></i>
                    Sign In to Book

                  </a>

                <% } %>

              </div>

            </div>

          </div>

        </div>

        <% }) %>

      <% } else { %>

        <div class="col-12 text-center">

          <h3>No events available yet</h3>

        </div>

      <% } %>

    </div>

  </div>

</section>

<!-- features section -->

<section class="section section-dark">

  <div class="container">

    <div class="row g-4 stagger-children">

      <%
        const features = [
          {
            icon: 'bi-shield-check',
            title: 'Secure Booking',
            desc: 'Passwords hashed with bcrypt and protected routes.'
          },
          {
            icon: 'bi-lightning-charge',
            title: 'Instant Confirmation',
            desc: 'Real-time booking and ticket availability.'
          },
          {
            icon: 'bi-people',
            title: 'Access Control',
            desc: 'Separate admin and user roles for security.'
          },
          {
            icon: 'bi-graph-up',
            title: 'Live Analytics',
            desc: 'Track bookings and event performance.'
          }
        ];
      %>

      <% features.forEach(f => { %>

      <div class="col-md-6 col-xl-3">

        <div class="event-card reveal">

          <div class="event-card-body">

            <div class="hero-icon-box mb-3">
              <i class="bi <%= f.icon %>"></i>
            </div>

            <h4 class="event-card-title">
              <%= f.title %>
            </h4>

            <p class="hero-subtitle">
              <%= f.desc %>
            </p>

          </div>

        </div>

      </div>

      <% }) %>

    </div>

  </div>

</section>

<!-- call to action -->

<section class="section section-mid">

  <div class="container">

    <div class="event-card text-center p-5 reveal">

      <div class="section-label">
        Ready to join?
      </div>

      <h2 class="hero-title">
        YOUR NEXT EVENT IS
        <span class="line-accent">
          WAITING
        </span>
      </h2>

      <p class="hero-subtitle mx-auto">
        Create a free account and start booking tickets to the events that matter most to you.
      </p>

      <div class="d-flex gap-3 justify-content-center flex-wrap">

        <a href="/auth/register" class="btn btn-primary">
          <i class="bi bi-person-plus"></i>
          Create Free Account
        </a>

        <a href="#events" class="btn btn-outline">
          <i class="bi bi-arrow-down"></i>
          Browse Events
        </a>

      </div>

    </div>

  </div>

</section>

<%- include('partials/footer') %>