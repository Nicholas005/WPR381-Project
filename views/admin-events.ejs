<%- include('partials/header') %>

<div class="bg-grid"></div>
<div class="bg-orbs"></div>

<main class="container admin-section">
    
    <div class="admin-header">
        <div>
            <div class="hero-eyebrow">
                <span class="hero-eyebrow-dot"></span>
                Staff Control Panel
            </div>
            <h2 class="hero-title-line2 admin-title">Manage Events</h2>
        </div>
        
        <button class="btn btn-primary btn-xl">
            CREATE NEW EVENT
        </button>
    </div>

    <div class="table-container fade-in">
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Category</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Tech Gala 2025</td>
                    <td>
                        <span class="float-badge-available">CORPORATE</span>
                    </td>
                    <td class="action-btn-group">
                        <button class="btn btn-sm btn-ghost">Edit</button>
                        <button class="btn btn-sm btn-ghost btn-delete">Delete</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <% if (typeof events === 'undefined' || events.length === 0) { %>
        <div class="empty-state" style="text-align: center; padding: 4rem; color: var(--textSecondary);">
            <p>No events found in the database.</p>
        </div>
    <% } %>

</main>

<%- include('partials/footer') %>