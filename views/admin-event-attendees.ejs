<%- include('partials/header') %>

<div class="bg-grid"></div>
<div class="bg-orbs"></div>

<main class="container admin-section">

    <div class="admin-header">
        <div>
            <div class="hero-eyebrow">
                <span class="hero-eyebrow-dot"></span>
                Staff Control Panel
            </div>
            <h2 class="hero-title-line2 admin-title">Attendees — <%= event.Name %></h2>
            <p style="color: var(--text-secondary); margin-top: 0.5rem;">
                <%= event.Category %> &nbsp;|&nbsp;
                <%= new Date(event.Date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %> &nbsp;|&nbsp;
                <%= event.Capacity - (event.Bookings || 0) %> / <%= event.Capacity %> spots remaining
            </p>
        </div>
        <a href="/admin/events" class="btn btn-ghost">← Back to Events</a>
    </div>

    <div class="table-container fade-in">
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Tickets</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (bookings && bookings.length > 0) { %>
                    <% bookings.forEach(booking => { %>
                        <tr>
                            <td style="font-weight: 600; color: white;">
                                <%= booking.UserID ? booking.UserID.Name : 'Deleted User' %>
                            </td>
                            <td style="color: var(--text-secondary);">
                                <%= booking.UserID ? booking.UserID.Email : '-' %>
                            </td>
                            <td><%= booking.Tickets %></td>
                            <td class="action-btn-group">

                                <!-- Edit tickets -->
                                <form action="/admin/events/<%= event._id %>/attendees/<%= booking._id %>/edit" 
                                      method="POST" style="display:flex; gap:0.4rem; align-items:center;">
                                    <input type="number" name="tickets" value="<%= booking.Tickets %>" 
                                           min="1" max="<%= event.Capacity %>"
                                           class="form-control" style="width: 65px; padding: 0.3rem 0.5rem;" />
                                    <button type="submit" class="btn btn-sm btn-ghost">Update</button>
                                </form>

                                <!-- Cancel booking -->
                                <form action="/admin/events/<%= event._id %>/attendees/<%= booking._id %>/cancel" 
                                      method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-ghost btn-delete">Remove</button>
                                </form>

                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                            No attendees yet for this event.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

</main>

<%- include('partials/footer') %>