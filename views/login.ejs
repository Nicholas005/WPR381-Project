<%- include('partials/header') %>
<div class="bg-grid"></div>
<div class="bg-orbs"></div>

<main class="container">
    <div class="hero-section-center">
        <div class="hero-eyebrow eyebrow-center">
            <span class="hero-eyebrow-dot"></span>
            Secure Access
        </div>

        <h1 class="hero-main-title">
            Welcome <span class="hero-accent">Back</span>
        </h1>
    </div>

    <div class="auth-card-wrapper fade-in">
        <form action="/auth/login" method="POST">
            <div class="mb-4">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="name@email.com" required>
            </div>

            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 mb-3">
                SIGN IN
            </button>
            
            <div class="text-center">
                <p class="auth-footer-text">
                    Don't have an account? <a href="/register" class="auth-link">Join the list</a>
                </p>
            </div>
        </form>
    </div>
</main>

<%- include('partials/footer') %>