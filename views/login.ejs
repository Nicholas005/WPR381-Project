<%- include('header') %>

<main class="container d-flex align-items-center justify-content-center" style="min-height: 80vh; margin-top: 50px;">
    <div class="table-container fade-in" style="max-width: 450px; width: 100%; padding: 3rem; background: var(--cardBg); border: 1px solid var(--border);">
        
        <div class="text-center mb-4">
            <div class="hero-eyebrow" style="justify-content: center;">
                <span class="hero-eyebrow-dot"></span>
                Secure Access
            </div>
            <h2 class="mt-2" style="color: var(--textPrimary); font-weight: 800;">Welcome Back</h2>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error" style="margin-bottom: 1rem;">
                <span><i class="bi bi-exclamation-triangle-fill"></i> <%= error %></span>
            </div>
        <% } %>

        <form action="/auth/login" method="POST">
            <div class="mb-4">
                <label class="form-label" style="color: var(--accent); font-size: 0.75rem; text-transform: uppercase;">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="name@email.com" required>
            </div>

            <div class="mb-4">
                <label class="form-label" style="color: var(--accent); font-size: 0.75rem; text-transform: uppercase;">Password</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 mb-3">
                SIGN IN
            </button>
            
            <div class="text-center">
                <p style="color: var(--textSecondary); font-size: 0.9rem;">
                    Don't have an account? <a href="/register" style="color: var(--accent); text-decoration: none; font-weight: 600;">Join the list</a>
                </p>
            </div>
        </form>
    </div>
</main>

<%- include('footer') %>