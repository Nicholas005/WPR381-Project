<%- include('partials/header') %>

<main class="section container" style="margin-top: 40px; padding-top: 0;">
    <div class="d-flex justify-content-between align-items-end mb-5 reveal" style="flex-wrap: wrap; gap: 20px;">
        <div class="text-start">
            <div class="hero-eyebrow" style="margin-bottom: 1rem;">
                <span class="hero-eyebrow-dot"></span>
                SYSTEM OVERVIEW
            </div>
            <h1 class="hero-title" style="margin: 0; white-space: nowrap;">
                Staff <span class="hero-title-line2">Control</span>
            </h1>
        </div>
        <div>
            <a href="/admin/events" class="btn btn-primary px-4 py-3" style="font-weight: 700; display: flex; align-items: center; gap: 10px;">
                MANAGE ALL EVENTS
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5 reveal">
    <div class="col-md-4">
        <div class="table-container" style="padding: 2rem; border-left: 4px solid var(--accent);">
            <small style="color: var(--accent); letter-spacing: 1px;">TOTAL REVENUE</small>
            <h2 style="color: white; margin-top: 5px;">
                R <%= totalRevenue ? totalRevenue.toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %>
            </h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-container" style="padding: 2rem; border-left: 4px solid #6c63ff;">
            <small style="color: #6c63ff; letter-spacing: 1px;">TOTAL BOOKINGS</small>
            <h2 style="color: white; margin-top: 5px;"><%= totalBookings || 0 %></h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-container" style="padding: 2rem; border-left: 4px solid #A855F7;">
            <small style="color: #A855F7; letter-spacing: 1px;">LIVE EVENTS</small>
            <h2 style="color: white; margin-top: 5px;"><%= totalEvents || 0 %></h2>
        </div>
    </div>
</div>

<div class="row g-4 mt-2 reveal">
<div class="col-md-6">
    <div class="table-container"
     style="padding: 2rem; border-left: 4px solid #C084FC;">
      <h4 style="color: #C084FC; margin-bottom: 1.25rem;">Most Booked Events</h4>
      <% if (popularEvents && popularEvents.length > 0) { %>
        <table style="width:100%; border-collapse: collapse;">
          <thead>
            <tr style="color: var(--text-secondary); font-size: 0.8rem; letter-spacing: 0.1em;">
              <th style="padding: 0.5rem 1rem; text-align:left;">EVENT</th>
              <th style="padding: 0.5rem 1rem; text-align:right;">TICKETS SOLD</th>
            </tr>
          </thead>
          <tbody>
            <% popularEvents.forEach((e, i) => { %>
              <tr style="border-top: 1px solid rgba(255,255,255,0.06);">
                <td style="padding: 0.75rem 1rem; color: white;"><%= i+1 %>. <%= e.name %></td>
                <td style="padding: 0.75rem 1rem; color: var(--accent); text-align:right; font-weight:700;"><%= e.totalTickets %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p style="color: var(--text-secondary);">No bookings yet.</p>
      <% } %>
    </div>
  </div>
</div>

<div class="row g-4 mt-2 reveal">
    <div class="col-md-6">
    <div class="table-container" 
         style="padding: 2rem; border-left: 4px solid #4C1D95;">
      <h4 style="color: #4C1D95; margin-bottom: 1.25rem;">User Enquiries</h4>
      <% if (enquiries && enquiries.length > 0) { %>
        <table style="width:100%; border-collapse: collapse;">
          <thead>
            <tr style="color: var(--text-secondary); font-size: 0.8rem; letter-spacing: 0.1em;">
              <th style="padding: 0.5rem 1rem; text-align:left;">USER</th>
              <th style="padding: 0.5rem 1rem; text-align:left;">SUBJECT</th>
              <th style="padding: 0.5rem 1rem; text-align:left;">MESSAGE</th>
              <th style="padding: 0.5rem 1rem; text-align:left;">DATE</th>
            </tr>
          </thead>
          <tbody>
            <% enquiries.forEach(q => { %>
              <tr style="border-top: 1px solid rgba(255,255,255,0.06);">
                <td style="padding: 0.75rem 1rem; color: white;"><%= q.UserID ? q.UserID.Name : 'Unknown' %></td>
                <td style="padding: 0.75rem 1rem; color: var(--accent);"><%= q.Subject || '—' %></td>
                <td style="padding: 0.75rem 1rem; color: var(--text-secondary); max-width: 320px;"><%= q.Enquiry %></td>
                <td style="padding: 0.75rem 1rem; color: var(--text-secondary); white-space:nowrap;"><%= new Date(q.createdAt).toLocaleDateString('en-ZA') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p style="color: var(--text-secondary);">No enquiries submitted yet.</p>
      <% } %>
    </div>
  </div>
</div>

    <div class="row g-4 reveal">
        <div class="col-12">
            <div class="table-container" style="padding: 2rem; background: linear-gradient(90deg, rgba(108, 99, 255, 0.05), transparent);">
                <h4 style="color: white;">Database Connection: <span style="color: #00ff88;">ACTIVE</span></h4>
                <p style="color: var(--textSecondary); font-size: 0.9rem; margin: 0;">The system is currently synced.</p>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>