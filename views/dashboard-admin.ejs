<%- include('header') %>

<main class="section container" style="margin-top: 40px; padding-top: 0;">
    <div class="d-flex justify-content-between align-items-end mb-5 reveal" style="flex-wrap: wrap; gap: 20px;">
        <div class="text-start">
            <div class="hero-eyebrow" style="margin-bottom: 1rem;">
                <span class="hero-eyebrow-dot"></span>
                SYSTEM OVERVIEW
            </div>
            <h1 class="hero-title" style="margin: 0; white-space: nowrap;">
                Staff <span class="hero-title-line2">Control</span>
            </h1>
        </div>
        <div>
            <a href="/admin-events" class="btn btn-primary px-4 py-3" style="font-weight: 700; display: flex; align-items: center; gap: 10px;">
                ⚡ MANAGE ALL EVENTS
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5 reveal">
        <div class="col-md-4">
            <div class="table-container" style="padding: 2rem; border-left: 4px solid var(--accent);">
                <small style="color: var(--accent); letter-spacing: 1px;">TOTAL REVENUE</small>
                <h2 style="color: white; margin-top: 5px;">R45,200</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="table-container" style="padding: 2rem; border-left: 4px solid #00ff88;">
                <small style="color: #00ff88; letter-spacing: 1px;">ACTIVE USERS</small>
                <h2 style="color: white; margin-top: 5px;">1,204</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="table-container" style="padding: 2rem; border-left: 4px solid white;">
                <small style="color: white; letter-spacing: 1px;">LIVE EVENTS</small>
                <h2 style="color: white; margin-top: 5px;">12</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 reveal">
        <div class="col-12">
            <div class="table-container" style="padding: 2rem; background: linear-gradient(90deg, rgba(108, 99, 255, 0.05), transparent);">
                <h4 style="color: white;">Database Connection: <span style="color: #00ff88;">ACTIVE</span></h4>
                <p style="color: var(--textSecondary); font-size: 0.9rem; margin: 0;">The system is currently synced.</p>
            </div>
        </div>
    </div>
</main>

<%- include('footer') %>